}

// ══ SERVICES ══
function drawServices(){
  const svcs=[...new Set(F.map(c=>c.service))].sort();
  const aRev=s=>F.filter(c=>c.service===s&&c.status==='פעיל').reduce((t,c)=>t+c.revenue,0);
  const avgSat=s=>{const sc=F.filter(c=>c.service===s);return sc.length?(sc.reduce((t,c)=>t+c.satisfaction,0)/sc.length).toFixed(1):0;};
  const cnt=s=>F.filter(c=>c.service===s).length;
  const chP=s=>{const sc=F.filter(c=>c.service===s);return sc.length?((sc.filter(c=>c.status!=='פעיל').length/sc.length)*100).toFixed(1):0;};
  mkChart('cSvcRev','bar',svcs,[{label:'₪',data:svcs.map(aRev),backgroundColor:PAL.slice(0,svcs.length),borderRadius:3}],{lp:'top'});
  mkChart('cSvcSat','bar',svcs,[{label:'שביעות רצון',data:svcs.map(avgSat),backgroundColor:svcs.map(s=>avgSat(s)>=7?'rgba(34,211,160,.75)':avgSat(s)>=5?'rgba(245,166,35,.75)':'rgba(240,91,91,.75)'),borderRadius:3}],{lp:'top',yO:{min:3,max:9}});
  mkChart('cSvcCount','doughnut',svcs,[{data:svcs.map(cnt),backgroundColor:PAL.slice(0,svcs.length),borderWidth:2,borderColor:'#161b27'}]);
  const bars=document.getElementById('svcChurnBars');bars.innerHTML='';
  svcs.map(s=>({s,p:parseFloat(chP(s))})).sort((a,b)=>b.p-a.p).forEach(({s,p})=>{
    const col=p>38?'#f05b5b':p>33?'#f5a623':'#22d3a0';
    bars.innerHTML+=`<div class="hb-row"><div class="hb-label">${s}</div><div class="hb-track"><div class="hb-fill" style="width:${Math.min(p*2.3,100)}%;background:${col};color:#0f1117">${p}%</div></div></div>`;
  });
}

// ══ GEO ══
function drawGeo(){
  const cities=[...new Set(F.map(c=>c.city))].sort((a,b)=>F.filter(x=>x.city===b).length-F.filter(x=>x.city===a).length);
  const maxT=Math.max(...cities.map(c=>F.filter(x=>x.city===c).length),1);
  const cb=document.getElementById('cityBars');cb.innerHTML='';
  cities.forEach(city=>{
    const a=F.filter(c=>c.city===city&&c.status==='פעיל').length;
    const t=F.filter(c=>c.city===city).length;
    cb.innerHTML+=`<div class="hb-row"><div class="hb-label">${city}</div><div class="hb-track"><div class="hb-fill" style="width:${(t/maxT*100).toFixed(0)}%;background:rgba(34,211,160,.7);color:#0f1117">${a}/${t}</div></div></div>`;
  });
  const ccb=document.getElementById('cityChurnBars');ccb.innerHTML='';
  [...cities].sort((a,b)=>{
    const pa=F.filter(c=>c.city===a),pb=F.filter(c=>c.city===b);
    const ra=pa.length?pa.filter(c=>c.status!=='פעיל').length/pa.length:0;
    const rb=pb.length?pb.filter(c=>c.status!=='פעיל').length/pb.length:0;
    return rb-ra;
  }).forEach(city=>{
    const cs=F.filter(c=>c.city===city);
    const p=cs.length?(cs.filter(c=>c.status!=='פעיל').length/cs.length*100).toFixed(1):0;
    const col=p>40?'#f05b5b':p>33?'#f5a623':'#22d3a0';
    ccb.innerHTML+=`<div class="hb-row"><div class="hb-label">${city}</div><div class="hb-track"><div class="hb-fill" style="width:${Math.min(p*2.3,100)}%;background:${col};color:#0f1117">${p}%</div></div></div>`;
  });
  mkChart('cCityRev','bar',cities,[{label:'₪',data:cities.map(c=>F.filter(x=>x.city===c&&x.status==='פעיל').reduce((s,x)=>s+x.revenue,0)),backgroundColor:'rgba(245,166,35,.75)',borderRadius:3}],{lp:'top'});
}

// ══ TABLE ══
function renderTable(){
  const sv=document.getElementById('tSort').value;
  let rows=[...F];
  if(sv==='name') rows.sort((a,b)=>a.name.localeCompare(b.name,'he'));
  else if(sv==='port_d') rows.sort((a,b)=>b.portfolio-a.portfolio);
  else if(sv==='rev_d') rows.sort((a,b)=>b.revenue-a.revenue);
  else if(sv==='sat_a') rows.sort((a,b)=>a.satisfaction-b.satisfaction);
  else if(sv==='sat_d') rows.sort((a,b)=>b.satisfaction-a.satisfaction);
  else if(sv==='resp_d') rows.sort((a,b)=>b.response_h-a.response_h);
  const tot=rows.length,start=tIdx*PG,end=Math.min(start+PG,tot),page=rows.slice(start,end);
  document.getElementById('tCount').textContent=`${tot.toLocaleString()} רשומות`;
  document.getElementById('tPaging').textContent=`${start+1}–${end} מתוך ${tot.toLocaleString()}`;
  document.getElementById('btnPrev').disabled=tIdx===0;
  document.getElementById('btnNext').disabled=end>=tot;
  const body=document.getElementById('tBody');
  body.innerHTML=page.map(c=>{
    const dots=Array.from({length:10},(_,i)=>`<span class="sd${i<c.satisfaction?' on':''}"></span>`).join('');
    return `<tr>
      <td style="color:var(--muted);font-size:10px">${c.id}</td>
      <td style="font-weight:500">${c.name}</td>
      <td>${c.city}</td>
      <td><span style="background:var(--bg3);padding:2px 7px;border-radius:5px;font-size:10px">${c.service}</span></td>
      <td style="color:var(--muted)">${c.join}</td>
      <td>₪${c.portfolio.toLocaleString()}</td>
      <td>₪${c.revenue.toLocaleString()}</td>
      <td><div class="sat-wrap"><div class="sat-dots">${dots}</div><span style="font-size:10px;color:var(--muted);margin-right:4px">${c.satisfaction}</span></div></td>
      <td><span class="pill ${c.status==='פעיל'?'pill-on':'pill-off'}">${c.status==='פעיל'?'● פעיל':'○ עזב'}</span></td>
    </tr>`;
  }).join('');
}
function tPage(d){tIdx+=d;renderTable();}

// ══ NAV ══
function nav(name,el){
  curPage=name;
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  el.classList.add('active');
  draw();
}
function draw(){
  if(curPage==='overview') drawOverview();
  else if(curPage==='churn') drawChurn();
  else if(curPage==='services') drawServices();
  else if(curPage==='geo') drawGeo();
  else if(curPage==='explore') renderTable();
}
function refresh(){updateKPIs();updateInsights();draw();}

function exportExcel(){
  const btn=document.getElementById('exportBtn');
  btn.textContent='⏳ מייצר...';btn.disabled=true;
  setTimeout(()=>{
    try{
      const sorted=[...D.clients].sort((a,b)=>{
        const da=a.join.split('/').reverse().join('');
        const db=b.join.split('/').reverse().join('');
        return da.localeCompare(db);
      });
      const rows=sorted.map((c,i)=>({
        'client_id':'C'+(1000+i),
        'שם':c.name,'גיל':c.age,'מגדר':c.gender,'עיר':c.city,
        'סוג_שירות':c.service,'תאריך_הצטרפות':c.join,
        'סכום_תיק':c.portfolio,'הכנסה_חודשית':c.revenue,
        'מספר_פניות_שנה_אחרונה':c.inquiries,
        'זמן_תגובה_ממוצע_שעות':c.response_h,
        'שביעות_רצון':c.satisfaction,'סטטוס':c.status,
        'תאריך_נטישה':c.churn_date||''
      }));
      const ws=XLSX.utils.json_to_sheet(rows);
      ws['!cols']=[{wch:10},{wch:18},{wch:5},{wch:7},{wch:12},{wch:18},{wch:16},{wch:12},{wch:16},{wch:22},{wch:22},{wch:12},{wch:8},{wch:14}];
      const range=XLSX.utils.decode_range(ws['!ref']);
      for(let C=range.s.c;C<=range.e.c;C++){
        const addr=XLSX.utils.encode_cell({r:0,c:C});
        if(ws[addr])ws[addr].s={font:{bold:true,color:{rgb:'085041'}},fill:{fgColor:{rgb:'E1F5EE'}},alignment:{horizontal:'right'}};
      }
      const sm={};
      rows.forEach(r=>{
        if(!sm[r['סוג_שירות']])sm[r['סוג_שירות']]={total:0,active:0,rev:0};
        sm[r['סוג_שירות']].total++;
        if(r['סטטוס']==='פעיל'){sm[r['סוג_שירות']].active++;sm[r['סוג_שירות']].rev+=r['הכנסה_חודשית'];}
      });
      const summaryRows=Object.entries(sm).map(([s,v])=>({
        'סוג שירות':s,'סה"כ':v.total,'פעילים':v.active,'עזבו':v.total-v.active,
        'נטישה %':((v.total-v.active)/v.total*100).toFixed(1),'הכנסה חודשית':v.rev
      }));
      const ws2=XLSX.utils.json_to_sheet(summaryRows);
      ws2['!cols']=[{wch:18},{wch:10},{wch:10},{wch:10},{wch:12},{wch:18}];
      const wb=XLSX.utils.book_new();
      XLSX.utils.book_append_sheet(wb,ws,'לקוחות מתוקן');
      XLSX.utils.book_append_sheet(wb,ws2,'סיכום לפי שירות');
      const now=new Date();
      const stamp=`${now.getDate().toString().padStart(2,'0')}-${(now.getMonth()+1).toString().padStart(2,'0')}-${now.getFullYear()}`;
      XLSX.writeFile(wb,`מגדל_לקוחות_מתוקן_${stamp}.xlsx`);
      showToast('✅ הקובץ הורד — '+rows.length.toLocaleString()+' רשומות');
    }catch(e){showToast('❌ שגיאה');console.error(e);}
    btn.textContent='⬇ ייצא Excel מתוקן';btn.disabled=false;
  },50);
}

function showToast(msg){
  let t=document.getElementById('_toast');
  if(!t){t=document.createElement('div');t.id='_toast';
    t.style.cssText='position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);background:#1e2535;border:1px solid rgba(34,211,160,.4);color:#22d3a0;padding:11px 22px;border-radius:9px;font-size:13px;font-weight:600;font-family:Heebo,sans-serif;z-index:9999;transition:transform .4s cubic-bezier(.175,.885,.32,1.275);box-shadow:0 8px 24px rgba(0,0,0,.4)';
    document.body.appendChild(t);}
  t.textContent=msg;
  t.style.transform='translateX(-50%) translateY(0)';
  setTimeout(()=>t.style.transform='translateX(-50%) translateY(80px)',3200);
}

refresh();
</script>
