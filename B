function drawChurnQ(canvasId){
  const qm={};
  F.filter(c=>c.churn_q).forEach(c=>{qm[c.churn_q]=(qm[c.churn_q]||0)+1;});
  const qKeys=Object.keys(qm).sort();
  const qVals=qKeys.map(k=>qm[k]);
  if(qVals.length<2)return;
  const avgQ=qVals.reduce((s,v)=>s+v,0)/qVals.length;
  const n=qVals.length,xm=(n-1)/2;
  const num=qVals.reduce((s,v,i)=>s+(i-xm)*(v-avgQ),0);
  const den=qVals.reduce((s,_,i)=>s+(i-xm)**2,0);
  const sl=den?num/den:0,ic=avgQ-sl*xm;
  const trend=qVals.map((_,i)=>parseFloat((sl*i+ic).toFixed(1)));
  const barColors=qVals.map(v=>v>avgQ*1.2?'rgba(240,91,91,.85)':'rgba(91,142,240,.72)');
  mkChart(canvasId,'bar',qKeys,[
    {type:'bar',label:'נטישות ברבעון',data:qVals,backgroundColor:barColors,borderRadius:3,order:2},
    {type:'line',label:'קו מגמה',data:trend,borderColor:'rgba(245,166,35,.9)',backgroundColor:'transparent',pointRadius:0,borderWidth:2,tension:0,borderDash:[5,4],order:1}
  ],{lp:'top',xT:{maxRotation:45,autoSkip:true,maxTicksLimit:14},yO:{title:{display:true,text:'נטישות',color:'#8892a4'}}});
}

