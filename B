<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>מגדל שירותים פיננסיים — דשבורד מנכ"ל</title>
<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
:root{
  --bg:#0f1117;--bg2:#161b27;--bg3:#1e2535;
  --border:rgba(255,255,255,.08);--text:#e8eaf0;--muted:#8892a4;
  --green:#22d3a0;--green-l:rgba(34,211,160,.12);--green-d:#085041;
  --blue:#5b8ef0;--amber:#f5a623;--red:#f05b5b;--red-l:rgba(240,91,91,.12);
  --purple:#a78bfa;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Heebo',sans-serif;background:var(--bg);color:var(--text);direction:rtl;min-height:100vh}

/* TOPBAR */
.topbar{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 24px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.logo{display:flex;align-items:center;gap:10px}
.logo-mark{width:34px;height:34px;background:var(--green);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:17px;font-weight:800;color:#0f1117}
.logo-name{font-size:15px;font-weight:700}
.logo-sub{font-size:11px;color:var(--muted)}
.top-badge{background:var(--green-l);border:1px solid rgba(34,211,160,.3);color:var(--green);padding:4px 12px;border-radius:20px;font-size:12px;display:flex;align-items:center;gap:6px}
.top-badge-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}

/* LAYOUT */
.layout{display:flex;min-height:calc(100vh - 56px)}

/* SIDEBAR */
.sidebar{width:200px;background:var(--bg2);border-left:1px solid var(--border);padding:16px 0;position:sticky;top:56px;height:calc(100vh - 56px);overflow-y:auto;flex-shrink:0}
.nav-section{padding:0 12px 16px}
.nav-label{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:1px;padding:0 8px;margin-bottom:8px}
.nav-btn{width:100%;display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:8px;font-size:13px;color:var(--muted);cursor:pointer;border:none;background:none;font-family:'Heebo',sans-serif;text-align:right;transition:all .15s;margin-bottom:2px}
.nav-btn:hover{background:var(--bg3);color:var(--text)}
.nav-btn.active{background:var(--green-l);color:var(--green);font-weight:600}
.nav-icon{font-size:15px;width:18px;text-align:center;flex-shrink:0}

/* FILTER BAR */
.filter-bar{background:var(--bg2);border-bottom:1px solid var(--border);padding:10px 20px;display:flex;gap:12px;align-items:center;flex-wrap:wrap}
.filter-group{display:flex;align-items:center;gap:7px}
.filter-label{font-size:11px;color:var(--muted);white-space:nowrap}
select{background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:7px;padding:5px 10px;font-size:12px;font-family:'Heebo',sans-serif;cursor:pointer;outline:none;direction:rtl}
select:focus{border-color:var(--green)}
.btn-reset{background:none;border:1px solid var(--border);color:var(--muted);padding:5px 12px;border-radius:7px;font-size:12px;cursor:pointer;font-family:'Heebo',sans-serif;transition:all .15s}
.btn-reset:hover{border-color:var(--red);color:var(--red)}
.filter-info{font-size:12px;color:var(--muted);margin-right:auto}

/* MAIN */
.main{flex:1;padding:20px;overflow-x:hidden}
.page{display:none}.page.active{display:block}

/* KPI ROW */
.kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:20px}
.kpi{background:var(--bg2);border:1px solid var(--border);border-radius:11px;padding:14px 16px;border-bottom:3px solid transparent;transition:border-color .2s}
.kpi.c-green{border-bottom-color:var(--green)}
.kpi.c-red{border-bottom-color:var(--red)}
.kpi.c-amber{border-bottom-color:var(--amber)}
.kpi.c-blue{border-bottom-color:var(--blue)}
.kpi.c-purple{border-bottom-color:var(--purple)}
.kpi-label{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.7px;margin-bottom:7px}
.kpi-val{font-size:22px;font-weight:800;line-height:1}
.kpi-sub{font-size:11px;color:var(--muted);margin-top:4px}

/* INSIGHT ROW */
.insight-row{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:20px}
.insight{border-radius:9px;padding:12px 14px;border:1px solid}
.insight.ok{background:var(--green-l);border-color:rgba(34,211,160,.3);color:var(--green)}
.insight.warn{background:rgba(245,166,35,.1);border-color:rgba(245,166,35,.3);color:var(--amber)}
.insight.bad{background:var(--red-l);border-color:rgba(240,91,91,.3);color:var(--red)}
.insight-title{font-size:12px;font-weight:700;margin-bottom:3px}
.insight-body{font-size:11px;opacity:.8;line-height:1.5}

/* CARDS */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:14px}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:11px;padding:18px;margin-bottom:14px}
.card-head{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px}
.card-title{font-size:13px;font-weight:600}
.card-sub{font-size:11px;color:var(--muted);margin-top:2px}
canvas{max-height:230px}

/* SEG */
.seg{display:flex;background:var(--bg3);border-radius:7px;padding:2px;gap:1px}
.seg-btn{padding:4px 10px;border-radius:5px;font-size:11px;font-weight:600;cursor:pointer;color:var(--muted);border:none;background:none;font-family:'Heebo',sans-serif}
.seg-btn.active{background:var(--bg2);color:var(--text)}

/* HBARS */
.hb-row{display:flex;align-items:center;gap:8px;margin-bottom:8px;font-size:12px}
.hb-label{width:108px;text-align:right;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.hb-track{flex:1;background:var(--bg3);border-radius:3px;height:20px;overflow:hidden}
.hb-fill{height:100%;border-radius:3px;display:flex;align-items:center;padding-right:7px;font-size:11px;font-weight:700}

/* TABLE */
.table-wrap{overflow-x:auto;max-height:440px;overflow-y:auto}
table{width:100%;border-collapse:collapse;font-size:12px}
thead{position:sticky;top:0;z-index:5}
th{background:var(--bg3);color:var(--muted);font-weight:600;font-size:10px;padding:9px 12px;text-align:right;border-bottom:1px solid var(--border);text-transform:uppercase;letter-spacing:.5px;white-space:nowrap}
td{padding:8px 12px;border-bottom:1px solid rgba(255,255,255,.04);white-space:nowrap}
tr:hover td{background:rgba(255,255,255,.015)}
.pill{display:inline-flex;padding:2px 8px;border-radius:20px;font-size:11px;font-weight:600}
.pill-on{background:var(--green-l);color:var(--green)}
.pill-off{background:var(--red-l);color:var(--red)}
.sat-wrap{display:flex;align-items:center;gap:5px}
.sat-dots{display:flex;gap:2px}
.sd{width:5px;height:5px;border-radius:50%;background:var(--bg3)}
.sd.on{background:var(--amber)}
.paging{display:flex;align-items:center;justify-content:space-between;padding:10px 16px;border-top:1px solid var(--border);font-size:12px;color:var(--muted)}
.pg-btn{background:var(--bg3);border:1px solid var(--border);color:var(--text);padding:4px 12px;border-radius:6px;font-size:12px;cursor:pointer;font-family:'Heebo',sans-serif}
.pg-btn:hover{border-color:var(--green);color:var(--green)}
.pg-btn:disabled{opacity:.3;cursor:default}

@media(max-width:860px){.sidebar{display:none}.kpi-row{grid-template-columns:repeat(3,1fr)}.g2,.g3{grid-template-columns:1fr}.insight-row{grid-template-columns:1fr}}
</style>
</head>
<body>

<header class="topbar">
  <div class="logo">
    <div class="logo-mark">מ</div>
    <div>
      <div class="logo-name">מגדל שירותים פיננסיים</div>
      <div class="logo-sub">דשבורד ניהולי — מנכ"ל</div>
    </div>
  </div>
  <div style="display:flex;align-items:center;gap:10px">
    <div class="top-badge"><span class="top-badge-dot"></span>2,000 לקוחות</div>
    <button onclick="exportExcel()" id="exportBtn" style="display:flex;align-items:center;gap:7px;background:linear-gradient(135deg,#22d3a0,#1aab84);color:#0f1117;border:none;border-radius:8px;padding:7px 16px;font-size:12px;font-weight:700;font-family:'Heebo',sans-serif;cursor:pointer;transition:all .2s">
      ⬇ ייצא Excel מתוקן
    </button>
  </div>
</header>

<div class="layout">

<nav class="sidebar">
  <div class="nav-section">
    <div class="nav-label">תצוגות</div>
    <button class="nav-btn active" onclick="nav('overview',this)"><span class="nav-icon">📊</span>סקירה כללית</button>
    <button class="nav-btn" onclick="nav('churn',this)"><span class="nav-icon">📉</span>ניתוח נטישה</button>
    <button class="nav-btn" onclick="nav('services',this)"><span class="nav-icon">🏷️</span>לפי שירות</button>
    <button class="nav-btn" onclick="nav('geo',this)"><span class="nav-icon">🗺️</span>לפי עיר</button>
    <button class="nav-btn" onclick="nav('explore',this)"><span class="nav-icon">🔍</span>חקר נתונים</button>
  </div>
</nav>

<div style="flex:1;display:flex;flex-direction:column;overflow:hidden">

  <div class="filter-bar">
    <div class="filter-group">
      <span class="filter-label">עיר</span>
      <select id="fCity" onchange="applyFilters()"><option value="">כל הערים</option></select>
    </div>
    <div class="filter-group">
      <span class="filter-label">שירות</span>
      <select id="fService" onchange="applyFilters()"><option value="">כל השירותים</option></select>
    </div>
    <div class="filter-group">
      <span class="filter-label">סטטוס</span>
      <select id="fStatus" onchange="applyFilters()">
        <option value="">הכל</option>
        <option value="פעיל">פעיל</option>
        <option value="לא פעיל">לא פעיל</option>
      </select>
    </div>
    <div class="filter-group">
      <span class="filter-label">מגדר</span>
      <select id="fGender" onchange="applyFilters()">
        <option value="">הכל</option>
        <option value="זכר">זכר</option>
        <option value="נקבה">נקבה</option>
      </select>
    </div>
    <div class="filter-group">
      <span class="filter-label">גיל</span>
      <select id="fAge" onchange="applyFilters()">
        <option value="">כל הגילאים</option>
        <option value="18-29">18–29</option>
        <option value="30-39">30–39</option>
        <option value="40-49">40–49</option>
        <option value="50-59">50–59</option>
        <option value="60+">60+</option>
      </select>
    </div>
    <button class="btn-reset" onclick="resetFilters()">נקה</button>
    <span class="filter-info" id="filterInfo">מציג את כל הלקוחות</span>
  </div>

  <div class="main">

    <!-- ═══ OVERVIEW ═══ -->
    <div id="page-overview" class="page active">
      <div class="kpi-row">
        <div class="kpi c-green"><div class="kpi-label">לקוחות</div><div class="kpi-val" id="k-total">—</div><div class="kpi-sub">בסינון הנוכחי</div></div>
        <div class="kpi c-green"><div class="kpi-label">פעילים</div><div class="kpi-val" id="k-active" style="color:var(--green)">—</div><div class="kpi-sub" id="k-apct"></div></div>
        <div class="kpi c-red"><div class="kpi-label">שיעור נטישה</div><div class="kpi-val" id="k-churn" style="color:var(--red)">—</div><div class="kpi-sub">מסה"כ</div></div>
        <div class="kpi c-amber"><div class="kpi-label">הכנסה חודשית</div><div class="kpi-val" id="k-rev" style="color:var(--amber)">—</div><div class="kpi-sub">פעילים בלבד</div></div>
        <div class="kpi c-purple"><div class="kpi-label">שביעות רצון</div><div class="kpi-val" id="k-sat" style="color:var(--purple)">—</div><div class="kpi-sub">ממוצע / 10</div></div>
      </div>
      <div class="insight-row" id="insights"></div>
      <div class="g2">
        <div class="card">
          <div class="card-head">
            <div><div class="card-title">התפלגות שביעות רצון</div><div class="card-sub" id="satAvgSub"></div></div>
            <div class="seg">
              <button class="seg-btn active" onclick="setSat('all',this)">הכל</button>
              <button class="seg-btn" onclick="setSat('active',this)">פעילים</button>
              <button class="seg-btn" onclick="setSat('inactive',this)">עזבו</button>
            </div>
          </div>
          <canvas id="cSat"></canvas>
        </div>
        <div class="card">
          <div class="card-head"><div><div class="card-title">לקוחות לפי שירות</div><div class="card-sub" id="svcChartSub">פעיל מול לא פעיל</div></div></div>
          <canvas id="cSvc"></canvas>
        </div>
      </div>
      <div class="card">
        <div class="card-head"><div>
          <div class="card-title">נטישה לאורך זמן — לפי רבעונים</div>
          <div class="card-sub">אדום = רבעון חריג | קו צהוב = מגמה</div>
        </div></div>
        <canvas id="cChurnQHome" style="max-height:220px"></canvas>
      </div>
    </div>

    <!-- ═══ CHURN ═══ -->
    <div id="page-churn" class="page">
      <div class="kpi-row" style="grid-template-columns:repeat(4,1fr)">
        <div class="kpi c-red"><div class="kpi-label">שיעור נטישה</div><div class="kpi-val" id="ch-pct" style="color:var(--red)">—</div></div>
        <div class="kpi c-amber"><div class="kpi-label">שירות בסיכון</div><div class="kpi-val" id="ch-worst" style="color:var(--amber);font-size:15px">—</div></div>
        <div class="kpi c-green"><div class="kpi-label">שירות יציב</div><div class="kpi-val" id="ch-best" style="color:var(--green);font-size:15px">—</div></div>
        <div class="kpi c-blue"><div class="kpi-label">זמן תגובה ממוצע</div><div class="kpi-val" id="ch-resp" style="color:var(--blue)">—</div></div>
      </div>
      <div class="card">
        <div class="card-head"><div>
          <div class="card-title">נטישה לאורך זמן — לפי רבעונים</div>
          <div class="card-sub">ציר X: שנים ורבעונים | אדום = רבעון חריג | קו צהוב = מגמה</div>
        </div></div>
        <canvas id="cChurnQ" style="max-height:280px"></canvas>
      </div>
      <div class="card">
        <div class="card-head"><div><div class="card-title">נטישה לפי סוג שירות</div></div></div>
        <div id="churnBars" style="padding-top:4px"></div>
      </div>
    </div>

    <!-- ═══ SERVICES ═══ -->
    <div id="page-services" class="page">
      <div class="g2">
        <div class="card"><div class="card-head"><div><div class="card-title">הכנסה חודשית לפי שירות</div><div class="card-sub">₪ — פעילים בלבד</div></div></div><canvas id="cSvcRev"></canvas></div>
        <div class="card"><div class="card-head"><div><div class="card-title">שביעות רצון לפי שירות</div></div></div><canvas id="cSvcSat"></canvas></div>
      </div>
      <div class="g2">
        <div class="card"><div class="card-head"><div><div class="card-title">נטישה לפי שירות (%)</div></div></div><div id="svcChurnBars" style="padding-top:4px"></div></div>
        <div class="card"><div class="card-head"><div><div class="card-title">מספר לקוחות לפי שירות</div></div></div><canvas id="cSvcCount"></canvas></div>
      </div>
    </div>

    <!-- ═══ GEO ═══ -->
    <div id="page-geo" class="page">
      <div class="g2">
        <div class="card"><div class="card-head"><div><div class="card-title">לקוחות לפי עיר</div><div class="card-sub">פעיל / עזב</div></div></div><div id="cityBars" style="padding-top:4px"></div></div>
        <div class="card"><div class="card-head"><div><div class="card-title">נטישה לפי עיר (%)</div></div></div><div id="cityChurnBars" style="padding-top:4px"></div></div>
      </div>
      <div class="card"><div class="card-head"><div><div class="card-title">הכנסה חודשית לפי עיר</div><div class="card-sub">₪ — פעילים בלבד</div></div></div><canvas id="cCityRev" style="max-height:240px"></canvas></div>
    </div>

    <!-- ═══ EXPLORE ═══ -->
    <div id="page-explore" class="page">
      <div style="display:flex;gap:12px;align-items:center;margin-bottom:14px;background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:12px 16px">
        <span style="font-size:12px;color:var(--muted)">מיין לפי:</span>
        <select id="tSort" onchange="renderTable()" style="min-width:180px">
          <option value="name">שם</option>
          <option value="port_d">תיק — גבוה לנמוך</option>
          <option value="rev_d">הכנסה — גבוה לנמוך</option>
          <option value="sat_a">שביעות רצון — נמוך לגבוה</option>
          <option value="sat_d">שביעות רצון — גבוה לנמוך</option>
          <option value="resp_d">זמן תגובה — גבוה לנמוך</option>
        </select>
        <span id="tCount" style="font-size:12px;color:var(--muted);margin-right:auto"></span>
      </div>
      <div class="card" style="padding:0;overflow:hidden">
        <div class="table-wrap">
          <table>
            <thead><tr>
              <th>ID</th><th>שם</th><th>עיר</th><th>שירות</th>
              <th>הצטרפות</th><th>תיק ₪</th><th>הכנסה/חודש</th>
              <th>שביעות רצון</th><th>סטטוס</th>
            </tr></thead>
            <tbody id="tBody"></tbody>
          </table>
        </div>
        <div class="paging">
          <span id="tPaging"></span>
          <div style="display:flex;gap:6px">
            <button class="pg-btn" id="btnPrev" onclick="tPage(-1)">→ הקודם</button>
            <button class="pg-btn" id="btnNext" onclick="tPage(1)">הבא ←</button>
          </div>
        </div>
      </div>
    </div>

  </div><!-- /main -->
</div><!-- /flex col -->
