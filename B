  const sc=Object.entries(sm).map(([s,v])=>({s,p:(v.t-v.a)/v.t*100})).sort((a,b)=>b.p-a.p);
  document.getElementById('ch-worst').textContent=sc.length?`${sc[0].s} (${sc[0].p.toFixed(0)}%)`:'—';
  document.getElementById('ch-best').textContent=sc.length?`${sc[sc.length-1].s} (${sc[sc.length-1].p.toFixed(0)}%)`:'—';
  document.getElementById('ch-resp').textContent=F.length?(F.reduce((s,c)=>s+c.response_h,0)/F.length).toFixed(1)+'h':'—';

